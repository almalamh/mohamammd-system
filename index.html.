function importData(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    try {
      const imported = JSON.parse(ev.target.result);
      if (imported.purchases || imported.balanceLog || typeof imported.balance === 'number') {
        if (!confirm('هل تريد دمج البيانات مع الموجودة؟\n(اختر "إلغاء" لاستبدال الكل)')) {
          data = imported;
        } else {
          if (imported.purchases) data.purchases = [...data.purchases, ...imported.purchases];
          if (imported.balanceLog) data.balanceLog = [...data.balanceLog, ...imported.balanceLog];
          if (typeof imported.balance === 'number') data.balance += imported.balance;
        }
        if (!data.purchases) data.purchases = [];
        if (!data.balanceLog) data.balanceLog = [];
        if (!data.workers) data.workers = [];
        if (!data.warehouse) data.warehouse = [];
        if (!data.inventory) data.inventory = [];
        if (!data.attendance) data.attendance = [];
        if (!data.attMonthly) data.attMonthly = {};
        if (!data.warehouseReports) data.warehouseReports = [];
        if (typeof data.balance !== 'number') data.balance = 0;
        // Recalculate balance from log
        const totalAdd = data.balanceLog.filter(x => x.type === 'add').reduce((s, x) => s + x.amount, 0);
        const totalSpent = data.balanceLog.filter(x => x.type === 'purchase').reduce((s, x) => s + x.amount, 0);
        data.balance = totalAdd - totalSpent;
        saveData();
        toast('✅ تم استيراد البيانات');
      } else {
        toast('❌ ملف غير صالح', 'error');
      }
    } catch(err) {
      toast('❌ خطأ في قراءة الملف', 'error');
    }
  };
  reader.readAsText(file);
  e.target.value = '';
}

