<!-- Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h3 id="modalTitle">تعديل</h3>
    <div id="modalBody"></div>
    <div class="btn-group" id="modalDefaultButtons">
      <button class="btn btn-primary" onclick="modalSave()">💾 حفظ التعديلات</button>
      <button class="btn btn-outline" onclick="closeModal()">❌ إلغاء</button>
    </div>
  </div>
</div>

<!-- Toast container -->
<div class="toast-container" id="toastContainer"></div>

<script>
// ========== DATA ==========
let data = { balance: 0, balanceLog: [], purchases: [], workers: [], warehouse: [], inventory: [], attendance: [], attMonthly: {}, warehouseReports: [], salaries: [] };
let editingType = null;
let editingId = null;

function loadData() {
  try {
    const saved = localStorage.getItem('erpData');
    if (saved) {
      data = JSON.parse(saved);
      if (!data.balanceLog) data.balanceLog = [];
      if (!data.purchases) data.purchases = [];
      if (!data.workers) data.workers = [];
      if (!data.warehouse) data.warehouse = [];
      if (!data.inventory) data.inventory = [];
      if (!data.attendance) data.attendance = [];
      if (!data.attMonthly) data.attMonthly = {};
      if (!data.warehouseReports) data.warehouseReports = [];
      if (!data.salaries) data.salaries = [];
      if (typeof data.balance !== 'number') data.balance = 0;
    }
  } catch(e) { console.error(e); }
  mergeWarehouseReports();
}

function mergeWarehouseReports() {
  const reports = data.warehouseReports || [];
  const seen = {};
  const merged = [];
  reports.forEach(r => {
    const key = r.branch + '|' + r.date;
    if (seen[key] !== undefined) {
      const idx = seen[key];
      merged[idx].items.push(...(r.items || []));
      if (r.time < merged[idx].time) merged[idx].time = r.time;
    } else {
      seen[key] = merged.length;
      merged.push({ ...r, items: [...(r.items || [])] });
    }
  });
  data.warehouseReports = merged;
}

function saveData() {
  try { localStorage.setItem('erpData', JSON.stringify(data)); } catch(e) { console.error(e); }
  updateAll();
}

function toast(msg, type = 'success') {
  const el = document.createElement('div');
  el.className = 'toast toast-' + type;
  el.textContent = msg;
  document.getElementById('toastContainer').appendChild(el);
  setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity .3s'; setTimeout(() => el.remove(), 300); }, 3000);
}

// ========== TABS ==========
function switchTab(tab) {
  document.querySelectorAll('.content-section').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.sidebar-link').forEach(b => b.classList.remove('active'));
  document.getElementById('section-' + tab).classList.add('active');
  document.querySelector(`.sidebar-link[data-section="${tab}"]`).classList.add('active');
}

function toggleCard(el) {
  const card = el.closest('.card');
  if (!card) return;
  card.classList.toggle('collapsed');
}

function toggleSidebar() {
  const sidebar = document.querySelector('.sidebar');
  const btn = document.querySelector('.sidebar-toggle');
  sidebar.classList.toggle('collapsed');
  btn.textContent = sidebar.classList.contains('collapsed') ? '▶' : '◀';
}

// ========== BALANCE ==========
function addToBalance(e) {
  e.preventDefault();
  const amount = parseFloat(document.getElementById('bAmount').value);
  const note = document.getElementById('bNote').value.trim() || 'إضافة رصيد';
  const date = document.getElementById('bDate').value;

  if (isNaN(amount) || amount <= 0) { toast('يرجى إدخال مبلغ صحيح', 'error'); return; }

  data.balance += amount;
  data.balanceLog.push({
    id: Date.now() + Math.random(),
    amount: amount,
    type: 'add',
    note: note,
    date: date,
    createdAt: new Date().toISOString()
  });

  saveData();
  document.getElementById('balanceForm').reset();
  populateHijriDropdowns();
  setTodayDate('bDate');
  toast('✅ تم إضافة ' + amount.toLocaleString('en-US') + ' ر.س للعهدة');
}

function deleteBalanceEntry(id) {
  if (!confirm('هل أنت متأكد من الحذف؟')) return;
  const entry = data.balanceLog.find(x => x.id === id);
  if (!entry) return;
  if (entry.type === 'add') {
    data.balance -= entry.amount;
  }
  data.balanceLog = data.balanceLog.filter(x => x.id !== id);
  saveData();
  toast('🗑️ تم الحذف واسترجاع المبلغ');
}
function renderBalanceLog() {
  const search = document.getElementById('bSearch').value.trim().toLowerCase();
  let list = [...data.balanceLog].sort((a, b) => new Date(b.date) - new Date(a.date));
  if (search) list = list.filter(x => (x.note || '').toLowerCase().includes(search));

  const tbody = document.getElementById('balanceLogBody');
  const empty = document.getElementById('balanceLogEmpty');

  const foot = document.getElementById('balanceFoot');
  if (list.length === 0) {
    tbody.innerHTML = '';
    foot.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  tbody.innerHTML = list.map((x, i) => {
    return `<tr>
      <td class="text-muted">${i + 1}</td>
      <td>${x.note || '-'}</td>
      <td>${Number(x.amount || 0).toLocaleString('en-US')} ر.س</td>
      <td>${x.date || '-'}</td>
      <td>
        <div class="actions">
          <button class="btn btn-sm btn-danger" onclick="deleteBalanceEntry(${x.id})">🗑️</button>
        </div>
      </td>
    </tr>`;
  }).join('');
  const totalExpenses = list.filter(x => x.type === 'purchase').reduce((s, x) => s + (x.amount || 0), 0);
  foot.innerHTML = `<tr><td colspan="2"></td><td style="text-align:right;font-weight:bold;font-size:14px;padding:8px;border-top:2px solid #1e3a5f">${totalExpenses.toLocaleString('en-US')}</td><td colspan="2"></td></tr>`;
}

// ========== PURCHASES ==========
function addPurchase(e) {
  e.preventDefault();
  const item = document.getElementById('pItemName').value.trim();
  const price = parseFloat(document.getElementById('pPrice').value);
  const date = document.getElementById('pDate').value;

  if (!item || isNaN(price) || price <= 0) { toast('يرجى تعبئة جميع الحقول', 'error'); return; }
  if (price > data.balance) { toast('⚠️ الرصيد غير كافٍ! المبلغ المتبقي: ' + data.balance.toLocaleString('en-US') + ' ر.س', 'error'); return; }

  data.balance -= price;
  const purchaseId = Date.now() + Math.random();
  data.purchases.push({
    id: purchaseId,
    itemName: item,
    price: price,
    date: date,
    createdAt: new Date().toISOString()
  });
  data.balanceLog.push({
    id: Date.now() + Math.random() + 1,
    amount: price,
    type: 'purchase',
    note: 'مشتريات: ' + item,
    date: date,
    purchaseId: purchaseId,
    createdAt: new Date().toISOString()
  });

  saveData();
  document.getElementById('purchaseForm').reset();
  setTodayDate('pDate');
  toast('✅ تمت إضافة المشتريات والرصيد المتبقي: ' + data.balance.toLocaleString('en-US') + ' ر.س');
}

function deletePurchase(id) {
  if (!confirm('هل أنت متأكد من الحذف؟')) return;
  const p = data.purchases.find(x => x.id === id);
  if (!p) return;
  data.balance += p.price;
  data.purchases = data.purchases.filter(x => x.id !== id);
  // Remove matching balance log entry
  const logIdx = data.balanceLog.findIndex(x => x.type === 'purchase' && x.purchaseId === id);
  if (logIdx !== -1) data.balanceLog.splice(logIdx, 1);
  else {
    // fallback for old entries without purchaseId: remove one matching entry (last one)
    for (let i = data.balanceLog.length - 1; i >= 0; i--) {
      const x = data.balanceLog[i];
      if (x.type === 'purchase' && x.amount === p.price && x.note === 'مشتريات: ' + p.itemName) {
        data.balanceLog.splice(i, 1);
        break;
      }
    }
  }
  saveData();
  toast('🗑️ تم الحذف واسترجاع ' + p.price.toLocaleString('en-US') + ' ر.س للعهدة');
}

function editPurchase(id) {
  const p = data.purchases.find(x => x.id === id);
  if (!p) return;
  editingType = 'purchase';
  editingId = id;
  document.getElementById('modalTitle').textContent = '✏️ تعديل المشتريات';
  document.getElementById('modalBody').innerHTML = `
    <div class="form-group" style="margin-bottom:.75rem">
      <label>اسم الصنف</label>
      <input type="text" id="mItemName" value="${p.itemName}" class="form-control">
    </div>
    <div class="form-group" style="margin-bottom:.75rem">
      <label>السعر</label>
      <input type="number" id="mPrice" value="${p.price}" min="0" step="0.01" class="form-control">
    </div>
    <div class="form-group" style="margin-bottom:.75rem">
      <label>التاريخ</label>
      <input type="date" id="mDate" value="${p.date}" class="form-control">
    </div>
  `;
  document.getElementById('modal').classList.add('open');
}

function renderPurchases() {
  const search = document.getElementById('pSearch').value.trim().toLowerCase();
  let list = data.purchases;
  if (search) list = list.filter(p => (p.itemName || '').toLowerCase().includes(search));
  list = [...list].sort((a, b) => new Date(b.date) - new Date(a.date));

  const tbody = document.getElementById('purchasesBody');
  const empty = document.getElementById('purchasesEmpty');
  const foot = document.getElementById('purchasesFoot');
  if (list.length === 0) { tbody.innerHTML = ''; foot.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  tbody.innerHTML = list.map((p, i) => `
    <tr>
      <td class="text-muted">${i + 1}</td>
      <td style="text-align:left"><strong>${p.itemName}</strong></td>
      <td style="text-align:right">${Number(p.price || 0).toLocaleString('en-US')} ر.س</td>
      <td style="text-align:left">${p.date}</td>
      <td>
        <div class="actions">
          <button class="btn btn-sm btn-warning" onclick="editPurchase(${p.id})">✏️</button>
          <button class="btn btn-sm btn-danger" onclick="deletePurchase(${p.id})">🗑️</button>
        </div>
      </td>
    </tr>
  `).join('');
  const total = list.reduce((s, p) => s + (p.price || 0), 0);
  foot.innerHTML = `<tr><td colspan="2"></td><td style="text-align:right;font-weight:bold;font-size:14px;padding:8px;border-top:2px solid #1e3a5f">${total.toLocaleString('en-US')}</td><td colspan="2"></td></tr>`;
}

function resetPurchaseForm() {
  document.getElementById('purchaseForm').reset();
  setTodayDate('pDate');
}

// ========== WORKERS ==========
function addWorker(e) {
  e.preventDefault();
  const name = document.getElementById('workerName').value.trim();
  const iqama = document.getElementById('wIqama').value.trim();
  const certNum = document.getElementById('certNumber').value.trim();
  const issueDate = getHijriDate('wIssueYear', 'wIssueMonth', 'wIssueDay');
  const expiryDate = getHijriDate('wExpiryYear', 'wExpiryMonth', 'wExpiryDay');

  if (!name || !iqama || !certNum || !issueDate || !expiryDate) { toast('يرجى تعبئة جميع الحقول المطلوبة', 'error'); return; }

  data.workers.push({
    id: Date.now() + Math.random(),
    name: name,
    iqamaNumber: iqama,
    certNumber: certNum,
    issueDate: issueDate,
    expiryDate: expiryDate,
    createdAt: new Date().toISOString()
  });

  saveData();
  document.getElementById('workerForm').reset();
  populateHijriDropdowns();
  toast('✅ تمت إضافة العامل بنجاح');
}

function deleteWorker(id) {
  if (!confirm('هل أنت متأكد من الحذف؟')) return;
  data.workers = data.workers.filter(w => w.id !== id);
  saveData();
  toast('🗑️ تم الحذف');
}

function editWorker(id) {
  const w = data.workers.find(x => x.id === id);
  if (!w) return;
  editingType = 'worker';
  editingId = id;
  document.getElementById('modalTitle').textContent = '✏️ تعديل العامل';
  const iParts = w.issueDate ? w.issueDate.split('-') : getHijriToday().split('-');
  const eParts = w.expiryDate ? w.expiryDate.split('-') : getHijriToday().split('-');
  document.getElementById('modalBody').innerHTML = `
    <div class="form-group" style="margin-bottom:.75rem">
      <label>اسم العامل</label>
      <input type="text" id="mName" value="${w.name}" class="form-control">
    </div>
    <div class="form-group" style="margin-bottom:.75rem">
      <label>رقم الإقامة</label>
      <input type="text" id="mIqama" value="${w.iqamaNumber}" class="form-control">
    </div>
    <div class="form-group" style="margin-bottom:.75rem">
      <label>رقم الشهادة الصحية</label>
      <input type="text" id="mCertNum" value="${w.certNumber}" class="form-control">
    </div>
    <div class="form-group" style="margin-bottom:.75rem">
      <label>تاريخ الإصدار (هـجري)</label>
      <div style="display:flex;gap:4px">
        <select id="mIssueDay" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:8px;font-size:13px;font-family:inherit"><option value="">اليوم</option></select>
        <select id="mIssueMonth" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:8px;font-size:13px;font-family:inherit">
          <option value="">الشهر</option>
          <option value="01">محرم</option><option value="02">صفر</option><option value="03">ربيع الأول</option>
          <option value="04">ربيع الثاني</option><option value="05">جمادى الأول</option><option value="06">جمادى الثاني</option>
          <option value="07">رجب</option><option value="08">شعبان</option><option value="09">رمضان</option>
          <option value="10">شوال</option><option value="11">ذو القعدة</option><option value="12">ذو الحجة</option>
        </select>
        <select id="mIssueYear" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:8px;font-size:13px;font-family:inherit"><option value="">السنة</option></select>
      </div>
    </div>
    <div class="form-group" style="margin-bottom:.75rem">
      <label>تاريخ الانتهاء (هـجري)</label>
      <div style="display:flex;gap:4px">
        <select id="mExpiryDay" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:8px;font-size:13px;font-family:inherit"><option value="">اليوم</option></select>
        <select id="mExpiryMonth" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:8px;font-size:13px;font-family:inherit">
          <option value="">الشهر</option>
          <option value="01">محرم</option><option value="02">صفر</option><option value="03">ربيع الأول</option>
          <option value="04">ربيع الثاني</option><option value="05">جمادى الأول</option><option value="06">جمادى الثاني</option>
          <option value="07">رجب</option><option value="08">شعبان</option><option value="09">رمضان</option>
          <option value="10">شوال</option><option value="11">ذو القعدة</option><option value="12">ذو الحجة</option>
        </select>
        <select id="mExpiryYear" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:8px;font-size:13px;font-family:inherit"><option value="">السنة</option></select>
      </div>
    </div>
  `;
  ['mIssueYear', 'mExpiryYear'].forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    for (let y = 1446; y <= 1455; y++) {
      const opt = document.createElement('option');
      opt.value = y.toString(); opt.textContent = y + ' هـ';
      sel.appendChild(opt);
    }
  });
  ['mIssueDay', 'mExpiryDay'].forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    for (let d = 1; d <= 30; d++) {
      const opt = document.createElement('option');
      opt.value = d.toString().padStart(2, '0'); opt.textContent = d;
      sel.appendChild(opt);
    }
  });
  if (document.getElementById('mIssueYear')) document.getElementById('mIssueYear').value = iParts[0];
  if (document.getElementById('mIssueMonth')) document.getElementById('mIssueMonth').value = iParts[1];
  if (document.getElementById('mIssueDay')) document.getElementById('mIssueDay').value = iParts[2];
  if (document.getElementById('mExpiryYear')) document.getElementById('mExpiryYear').value = eParts[0];
  if (document.getElementById('mExpiryMonth')) document.getElementById('mExpiryMonth').value = eParts[1];
  if (document.getElementById('mExpiryDay')) document.getElementById('mExpiryDay').value = eParts[2];
  document.getElementById('modal').classList.add('open');
}

function renderWorkers() {
  const search = document.getElementById('wSearch').value.trim().toLowerCase();
  let list = data.workers;
  if (search) list = list.filter(w => (w.name || '').toLowerCase().includes(search));

  const container = document.getElementById('workersCardsContainer');
  const empty = document.getElementById('workersEmpty');

  if (list.length === 0) { container.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  container.innerHTML = list.map((w, i) => {
    const diff = hijriDiffDays(w.expiryDate);
    const expired = diff < 0;
    const nearExpiry = !expired && diff <= 32;
    let topClass = 'valid';
    let topLabel = 'سارية';
    if (expired) { topClass = 'expired'; topLabel = 'منتهية'; }
    else if (nearExpiry) { topClass = 'near'; topLabel = 'قريبة من الانتهاء'; }
    return `<div class="health-card">
      <span class="card-badge ${topClass}">${topLabel}</span>
