function modalSave() {
  if (editingType === 'purchase') {
    const p = data.purchases.find(x => x.id === editingId);
    if (!p) return;
    const oldPrice = p.price;
    const oldName = p.itemName;
    const newPrice = parseFloat(document.getElementById('mPrice').value);
    const newName = document.getElementById('mItemName').value.trim();
    const newDate = document.getElementById('mDate').value;
    if (!newName || isNaN(newPrice)) { toast('يرجى تعبئة جميع الحقول', 'error'); return; }

    const diff = newPrice - oldPrice;
    if (diff > data.balance) { toast('⚠️ الرصيد غير كافٍ لتعديل السعر', 'error'); return; }

    data.balance -= diff;
    p.itemName = newName;
    p.price = newPrice;
    p.date = newDate;

    // Update balance log
    const logEntry = data.balanceLog.find(x => x.type === 'purchase' && x.amount === oldPrice && x.note === 'مشتريات: ' + oldName);
    if (logEntry) {
      logEntry.amount = newPrice;
      logEntry.note = 'مشتريات: ' + newName;
      logEntry.date = newDate;
    }

    saveData();
    toast('✅ تم التعديل');
  } else if (editingType === 'warehouse') {
    const w = data.warehouse.find(x => x.id === editingId);
    if (!w) return;
    w.code = document.getElementById('mWHCode').value.trim();
    w.name = document.getElementById('mWHName').value.trim();
    w.quantity = parseInt(document.getElementById('mWHQty').value);
    w.branch = document.getElementById('mWHBranch').value;
    if (!w.code || !w.name || isNaN(w.quantity) || !w.branch) { toast('يرجى تعبئة جميع الحقول', 'error'); return; }
    saveData();
    toast('✅ تم التعديل');
  } else if (editingType === 'inventory') {
    const item = data.inventory.find(x => x.id === editingId);
    if (!item) return;
    item.code = document.getElementById('mInvCode').value.trim();
    item.name = document.getElementById('mInvName').value.trim();
    item.quantity = parseInt(document.getElementById('mInvQty').value);
    if (!item.code || !item.name || isNaN(item.quantity)) { toast('يرجى تعبئة جميع الحقول', 'error'); return; }
    if (!item.code.startsWith('50')) { toast('⚠️ كود الصنف يجب أن يبدأ بـ 50', 'error'); return; }
    data.inventory.sort((a, b) => a.code.localeCompare(b.code, 'ar'));
    saveData();
    toast('✅ تم التعديل');
  } else if (editingType === 'worker') {
    const w = data.workers.find(x => x.id === editingId);
    if (!w) return;
    w.name = document.getElementById('mName').value.trim();
    w.iqamaNumber = document.getElementById('mIqama').value.trim();
    w.certNumber = document.getElementById('mCertNum').value.trim();
    const mIssue = getHijriDate('mIssueYear', 'mIssueMonth', 'mIssueDay');
    const mExpiry = getHijriDate('mExpiryYear', 'mExpiryMonth', 'mExpiryDay');
    if (mIssue) w.issueDate = mIssue;
    if (mExpiry) w.expiryDate = mExpiry;
    if (!w.name || !w.iqamaNumber || !w.certNumber || !w.issueDate || !w.expiryDate) { toast('يرجى تعبئة جميع الحقول', 'error'); return; }
    saveData();
    toast('✅ تم التعديل');
  }
  closeModal();
}

