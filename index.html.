<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نظام إدارة العهدة والمشتريات</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',Arial,sans-serif; }
body { background-color:#f8fafc; color:#334155; display:flex; min-height:100vh; overflow:hidden; }

/* ===== Sidebar ===== */
.sidebar {
  width:260px; background-color:#0f172a; color:#fff;
  display:flex; flex-direction:column; padding:20px;
  box-shadow:4px 0 10px rgba(0,0,0,.1); min-height:100vh; flex-shrink:0; overflow-y:auto;
  position:relative; transition:width .3s,padding .3s;
}
.sidebar.collapsed { width:44px; padding:8px; }
.sidebar.collapsed .sidebar-brand,
.sidebar.collapsed .sidebar-menu,
.sidebar.collapsed > div:last-child { display:none; }
.sidebar-toggle {
  position:absolute; left:-15px; top:50%; transform:translateY(-50%);
  width:30px; height:48px; background:#0f172a; border:1px solid #334155; border-left:none;
  border-radius:0 8px 8px 0; color:#94a3b8; cursor:pointer; z-index:20;
  font-size:13px; display:flex; align-items:center; justify-content:center;
  transition:all .3s; padding:0;
}
.sidebar-toggle:hover { background:#1e293b; color:#38bdf8; border-color:#38bdf8; }
.sidebar.collapsed .sidebar-toggle { left:7px; border-radius:8px; border:1px solid #334155; }
.sidebar-brand { font-size:20px; font-weight:700; margin-bottom:30px; text-align:center; border-bottom:1px solid #334155; padding-bottom:15px; color:#38bdf8; }
.sidebar-brand h1 { font-size:20px; margin:0; }
.sidebar-brand span { font-size:12px; color:#94a3b8; display:block; margin-top:4px; }
.sidebar-menu { list-style:none; display:flex; flex-direction:column; gap:6px; }
.sidebar-menu li a, .sidebar-link {
  color:#94a3b8; text-decoration:none; padding:12px 15px; border-radius:8px;
  display:block; font-weight:500; font-size:14px; transition:all .3s; cursor:pointer;
}
.sidebar-menu li a.active, .sidebar-menu li a:hover, .sidebar-link.active, .sidebar-link:hover {
  background-color:#38bdf8; color:#0f172a;
}
.sidebar-link .badge {
  display:inline-block; background:rgba(255,255,255,.1); padding:.1rem .4rem;
  border-radius:99px; font-size:.65rem; min-width:16px; text-align:center; margin-right:8px; float:left;
}
.logout-btn {
  background:transparent; border:1px solid rgba(255,255,255,.15); color:#94a3b8;
  padding:10px 14px; border-radius:8px; cursor:pointer; font-size:13px;
  font-weight:500; font-family:inherit; transition:all .3s;
}
.logout-btn:hover { background:rgba(56,189,248,.15); color:#38bdf8; }

/* ===== Main Content ===== */
.app-layout { display:flex; width:100%; }
.main-content { flex:1; padding:25px; overflow-y:auto; height:100vh; }
.section-header { margin-bottom:25px; padding-bottom:10px; border-bottom:2px solid #e2e8f0; }
.section-header h1 { font-size:24px; color:#1e293b; }
.content-section { display:none; }
.content-section.active { display:block; }

/* ===== Forms ===== */
.form-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:.75rem; margin-bottom:.75rem; }
.form-group { display:flex; flex-direction:column; }
.form-group label { font-size:.8125rem; font-weight:600; color:#1e293b; margin-bottom:.25rem; }
.form-group input, .form-group select {
  padding:.5rem .75rem; border:1px solid #cbd5e1; border-radius:8px;
  font-size:.875rem; transition:border-color .2s; font-family:inherit;
}
.form-group input:focus, .form-group select:focus {
  outline:none; border-color:#0284c7; box-shadow:0 0 0 3px rgba(2,132,199,.12);
}
.search-bar { display:flex; gap:.5rem; margin-bottom:1rem; }
.search-bar input {
  flex:1; padding:.5rem .75rem; border:1px solid #cbd5e1;
  border-radius:8px; font-size:.875rem; font-family:inherit;
}
.search-bar input:focus { outline:none; border-color:#0284c7; box-shadow:0 0 0 3px rgba(2,132,199,.12); }

/* ===== Buttons ===== */
.btn {
  display:inline-flex; align-items:center; gap:.375rem; padding:.5rem 1rem;
  border:none; border-radius:8px; font-size:.875rem; font-weight:500;
  cursor:pointer; transition:all .15s; font-family:inherit;
}
.btn-primary { background:#1e40af; color:#fff; }
.btn-primary:hover { background:#3b82f6; }
.btn-success { background:#059669; color:#fff; }
.btn-success:hover { background:#047857; }
.btn-danger { background:#dc2626; color:#fff; }
.btn-danger:hover { background:#b91c1c; }
.btn-warning { background:#d97706; color:#fff; }
.btn-warning:hover { background:#b45309; }
.btn-sm { padding:.375rem .75rem; font-size:.8125rem; }
.btn-outline { background:none; border:1px solid #cbd5e1; color:#64748b; }
.btn-outline:hover { background:#f1f5f9; }
.btn-group { display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.75rem; justify-content:flex-end; }

/* ===== Tables ===== */
.table-container {
  width:100%; overflow-x:auto; background:#fff; padding:15px;
  border-radius:12px; box-shadow:0 4px 6px -1px rgba(0,0,0,.05); margin-bottom:35px;
}
.table-wrapper { overflow-x:auto; border-radius:8px; border:1px solid #cbd5e1; margin-bottom:20px; }

table { width:100%; border-collapse:collapse; text-align:center; font-size:13px; font-weight:bold; }
th, td { border:1px solid #000000; padding:5px; }
.actions { display:flex; gap:.375rem; justify-content:center; }
.text-muted { color:#64748b; font-size:.8125rem; }

/* ===== Monthly Grid ===== */
#monthlyGrid { width:100%; border-collapse:collapse; font-size:14px; font-family:Arial,sans-serif; }
#monthlyGrid th, #monthlyGrid td { border:1px solid #7f7f7f; padding:4px 2px; text-align:center; font-weight:bold; color:#000; }
.header-title { background-color:#fff2cc; font-size:15px; padding:10px; }
.emp-name { background-color:#ffc000; min-width:50px; font-size:10px; overflow:hidden; white-space:nowrap; }
.sub-title { background-color:#ddebf7; font-size:11px; }
.day-col { background-color:#f2f2f2; width:55px; }
.bg-red { background-color:#ff0000 !important; color:#ff0000 !important; }
#monthlyGrid td:not(.bg-red):hover { background:#d4e6f1 !important; cursor:pointer; }
#monthlyGrid .bg-red:hover { cursor:pointer; }

/* ===== Stats Grid ===== */
.stats-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:16px; margin-bottom:24px; }
.stat-card { background:#fff; padding:16px; border-radius:10px; box-shadow:0 4px 6px -1px rgba(0,0,0,.05); border:1px solid #e2e8f0; }
.stat-card .stat-icon { font-size:1.1rem; margin-bottom:4px; }
.stat-card .stat-value { font-size:1.3rem; font-weight:700; color:#1e40af; }
.stat-card .stat-label { font-size:.75rem; color:#64748b; margin-top:2px; }

/* ===== Balance Card ===== */
.balance-card {
  background:linear-gradient(135deg,#1e40af,#3b82f6); color:#fff;
  border-radius:12px; padding:2rem; text-align:center;
  box-shadow:0 4px 24px rgba(0,0,0,.12); margin-bottom:1.5rem;
}
.balance-card .label { font-size:.875rem; opacity:.85; }
.balance-card .amount { font-size:2.5rem; font-weight:800; margin:.5rem 0; letter-spacing:-1px; }
.balance-card .sub { font-size:.8125rem; opacity:.7; }
.balance-card.danger { background:linear-gradient(135deg,#dc2626,#ef4444); }
.balance-card.warning { background:linear-gradient(135deg,#d97706,#f59e0b); }

/* ===== Cards (generic section card) ===== */
.card { background:#fff; padding:20px; border-radius:12px; box-shadow:0 4px 6px -1px rgba(0,0,0,.05); border:1px solid #e2e8f0; margin-bottom:24px; }
.card h2 { font-size:16px; font-weight:700; color:#1e293b; margin-bottom:12px; }

/* ===== Certificate Cards (legacy - kept for export compatibility) ===== */
.certificate-card .info-icon { margin-left:4px; }

/* ===== Health Cards for Workers ===== */
.cards-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  padding: 20px 0;
  direction: rtl;
}
.health-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 20px;
  position: relative;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
  overflow: hidden;
}
.health-card:hover {
  transform: translateY(-5px);
}
.health-card .card-badge {
  position: absolute;
  top: 15px;
  left: 15px;
  padding: 5px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: bold;
  z-index: 1;
}
.health-card .card-badge.valid { background: #059669; color: #fff; }
.health-card .card-badge.expired { background: #dc2626; color: #fff; }
.health-card .card-badge.near { background: #d97706; color: #fff; }
.health-card .card-info {
  margin: 10px 0;
  color: #64748b;
  font-size: 14px;
  line-height: 1.8;
}
.health-card .card-info strong {
  color: #1e293b;
}
.health-card .card-actions {
  display: flex;
  gap: 6px;
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px dashed #e2e8f0;
}
.health-card .card-actions .btn { font-size: .75rem; padding: 3px 10px; }
[data-theme="dark"] .health-card { background: #1e293b; border-color: #334155; }
[data-theme="dark"] .health-card .card-info { color: #94a3b8; }
[data-theme="dark"] .health-card .card-info strong { color: #f1f5f9; }
[data-theme="dark"] .health-card .card-actions { border-top-color: #334155; }

/* Collapsible cards */
.card.collapsed > :not(.card-toggle-header) { display: none; }
.card-toggle-header { cursor: pointer; user-select: none; }
.card-toggle-header:hover { opacity: .8; }
h2.card-toggle-header::after,
.flex-between.card-toggle-header h2::after {
  content: ' ▲'; font-size: 11px; opacity: .6; margin-right: 6px;
}
.card.collapsed h2.card-toggle-header::after,
.card.collapsed .flex-between.card-toggle-header h2::after {
  content: ' ▼';
}

.worker-form-card {
  background: #fff;
  border: 1px solid #e2e8f0;
}
.worker-form-card .worker-form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 15px;
  align-items: end;
}
.worker-form-card .worker-form-grid input[type="text"],
.worker-form-card .worker-form-grid input[type="date"],
.worker-form-card .worker-form-grid select {
  width: 100%;
  padding: 10px;
  background: #fff;
  border: 1px solid #cbd5e1;
  border-radius: 6px;
  color: #1e293b;
  font-size: 14px;
  font-family: inherit;
  box-sizing: border-box;
}
.worker-form-card .worker-form-grid .hijri-row {
  display: flex;
  gap: 4px;
}
.worker-form-card .worker-form-grid .hijri-row select {
  flex: 1;
  padding: 8px;
}
.worker-form-card .worker-form-grid label {
  display: block;
  margin-bottom: 5px;
  color: #64748b;
  font-size: 13px;
}
[data-theme="dark"] .worker-form-card {
  background: #1a2332;
  border-color: #2c3e50;
}
[data-theme="dark"] .worker-form-card .worker-form-grid input[type="text"],
[data-theme="dark"] .worker-form-card .worker-form-grid input[type="date"],
[data-theme="dark"] .worker-form-card .worker-form-grid select {
  background: #111823;
  border-color: #2c3e50;
  color: #fff;
}
[data-theme="dark"] .worker-form-card .worker-form-grid label {
  color: #bdc3c7;
}

/* ===== Modal ===== */
.modal-overlay {
  display:none; position:fixed; inset:0; background:rgba(0,0,0,.5);
  z-index:200; align-items:center; justify-content:center; padding:1rem;
}
.modal-overlay.open { display:flex; }
.modal {
  background:#fff; border-radius:12px; padding:1.5rem;
  width:100%; max-width:500px; box-shadow:0 4px 24px rgba(0,0,0,.12); animation:modal-in .2s ease;
}
@keyframes modal-in { from{transform:scale(.95);opacity:0} to{transform:scale(1);opacity:1} }
.modal h3 { font-size:1.125rem; font-weight:600; margin-bottom:1rem; }
.form-control { width:100%; padding:.5rem .75rem; border:1px solid #cbd5e1; border-radius:8px; font-size:.875rem; font-family:inherit; }

/* ===== Toast ===== */
.toast-container { position:fixed; bottom:1rem; left:1rem; z-index:300; display:flex; flex-direction:column; gap:.5rem; }
.toast {
  padding:.75rem 1rem; border-radius:8px; color:#fff;
  font-size:.875rem; animation:toast-in .3s ease; box-shadow:0 4px 24px rgba(0,0,0,.12);
}
.toast-success { background:#059669; }
.toast-error { background:#dc2626; }
.toast-info { background:#1e40af; }
@keyframes toast-in { from{transform:translateX(100px);opacity:0} to{transform:translateX(0);opacity:1} }

/* ===== Tags ===== */
.tag {
  display:inline-block; padding:.125rem .5rem; border-radius:99px;
  font-size:.75rem; font-weight:500;
}
.tag-green { background:#d1fae5; color:#065f46; }
.tag-red { background:#fee2e2; color:#991b1b; }
.tag-blue { background:#dbeafe; color:#1e40af; }
.tag-yellow { background:#fef3c7; color:#92400e; }

/* ===== Empty State ===== */
.empty-state { text-align:center; padding:2rem; color:#64748b; }
.empty-state .empty-icon { font-size:2.5rem; margin-bottom:.5rem; }

/* ===== Utility ===== */
.flex-between { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; }
.mt-1 { margin-top:1rem; }
.mb-1 { margin-bottom:1rem; }
.text-center { text-align:center; }

/* ===== Login ===== */
.login-overlay {
  position:fixed; inset:0; z-index:9999;
  background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 40%,#2563eb 100%);
  display:flex; align-items:center; justify-content:center;
}
.login-box {
  background:rgba(255,255,255,.97); border-radius:20px; padding:2.5rem 2rem 2rem;
  width:380px; max-width:92%; box-shadow:0 25px 80px rgba(0,0,0,.4);
  text-align:center; position:relative; backdrop-filter:blur(10px);
}
.login-box::before {
  content:''; position:absolute; top:0; left:50%; transform:translateX(-50%);
  width:60px; height:4px; background:linear-gradient(90deg,#fbbf24,#f59e0b);
  border-radius:0 0 4px 4px;
}
.login-box .login-brand { font-size:1.3rem; font-weight:800; color:#1e3a5f; margin-bottom:.25rem; letter-spacing:1px; }
.login-box .login-brand span { color:#fbbf24; }
.login-box .login-sub-brand { font-size:.7rem; color:#94a3b8; margin-bottom:1.5rem; letter-spacing:2px; text-transform:uppercase; }
.login-box h2 { font-size:1.1rem; font-weight:700; color:#1e293b; margin-bottom:.15rem; }
.login-box p { font-size:.8rem; color:#94a3b8; margin-bottom:1.25rem; }
.login-box input {
  width:100%; padding:.7rem .85rem; border:1.5px solid #e2e8f0; border-radius:10px;
  font-size:.9rem; text-align:right; font-family:inherit;
  transition:all .2s; margin-bottom:.75rem; background:#f8fafc;
}
.login-box input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,.12); background:#fff; }
.login-box .btn-login {
  width:100%; padding:.7rem; border:none; border-radius:10px;
  background:linear-gradient(135deg,#1e3a5f,#2563eb); color:#fff; font-size:.95rem; font-weight:600;
  cursor:pointer; font-family:inherit; transition:all .2s; letter-spacing:1px;
}
.login-box .btn-login:hover { background:linear-gradient(135deg,#162d50,#1d4ed8); transform:translateY(-1px); box-shadow:0 4px 15px rgba(37,99,235,.3); }
.login-box .btn-login:active { transform:translateY(0); }
.login-box .error { color:#dc2626; font-size:.8rem; margin-top:.5rem; }
.login-box .hint { font-size:.7rem; color:#94a3b8; margin-top:.75rem; }

/* ===== Dark Mode ===== */
[data-theme="dark"] body { background-color:#0f172a; color:#e2e8f0; }
[data-theme="dark"] .main-content { background-color:#0f172a; }
[data-theme="dark"] .card { background:#1e293b; border-color:#334155; }
[data-theme="dark"] .card h2 { color:#f1f5f9; }
[data-theme="dark"] .stat-card { background:#1e293b; border-color:#334155; }
[data-theme="dark"] .stat-card .stat-label { color:#94a3b8; }
[data-theme="dark"] .stat-card .stat-value { color:#60a5fa; }
[data-theme="dark"] .table-wrapper { border-color:#334155; }
[data-theme="dark"] table { background:#1e293b; }
[data-theme="dark"] th, [data-theme="dark"] td { border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] .form-group label { color:#e2e8f0; }
[data-theme="dark"] .form-group input, [data-theme="dark"] .form-group select { background:#1e293b; border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] .search-bar input { background:#1e293b; border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] .empty-state { color:#94a3b8; }
[data-theme="dark"] .text-muted { color:#94a3b8; }
[data-theme="dark"] .section-header h1 { color:#f1f5f9; }
[data-theme="dark"] .section-header { border-color:#334155; }
[data-theme="dark"] .flex-between { color:#e2e8f0; }
[data-theme="dark"] .btn-outline { border-color:#475569; color:#94a3b8; }
[data-theme="dark"] .btn-outline:hover { background:#334155; }
[data-theme="dark"] .modal { background:#1e293b; }
[data-theme="dark"] .modal h3 { color:#f1f5f9; }
[data-theme="dark"] .form-control { background:#1e293b; border-color:#475569; color:#e2e8f0; }
[data-theme="dark"] .toast { box-shadow:0 4px 24px rgba(0,0,0,.4); }

@media (max-width:768px) {
  .sidebar { width:200px; }
  .main-content { padding:16px; }
  .form-row { grid-template-columns:1fr; }
  .stats-grid { grid-template-columns:repeat(2,1fr); }
}
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div class="login-overlay" id="loginOverlay">
  <div class="login-box">
    <div class="login-brand">محمد <span>ابراهيم</span></div>
    <div class="login-sub-brand">بوابة الاسترخاء</div>
    <h2>تسجيل الدخول</h2>
    <p>الرجاء إدخال اسم المستخدم وكلمة المرور</p>
    <input type="text" id="loginUser" placeholder="👤 اسم المستخدم" onkeydown="if(event.key==='Enter')document.getElementById('loginInput').focus()" style="margin-bottom:.5rem">
    <input type="password" id="loginInput" placeholder="🔑 كلمة المرور" onkeydown="if(event.key==='Enter')checkLogin()">
    <button class="btn-login" type="button" onclick="checkLogin()">دخول</button>
    <div class="error" id="loginError"></div>

  </div>
</div>

<div class="app-layout">
  <aside class="sidebar">
    <button class="sidebar-toggle" onclick="toggleSidebar()" title="إظهار/إخفاء القائمة">◀</button>
    <div class="sidebar-brand">
      <h1>محمد ابراهيم</h1>
      <span>بوابة الاسترخاء</span>
    </div>
    <ul class="sidebar-menu">
      <li><a class="sidebar-link active" data-section="balance" onclick="switchTab('balance')">💳 العهدة</a></li>
      <li><a class="sidebar-link" data-section="purchases" onclick="switchTab('purchases')">🛒 المشتريات <span class="badge" id="purchasesCount">0</span></a></li>
      <li><a class="sidebar-link" data-section="workers" onclick="switchTab('workers')">👷 العمال <span class="badge" id="workersCount">0</span></a></li>
      <li><a class="sidebar-link" data-section="inventory" onclick="switchTab('inventory')">📦 المخزون <span class="badge" id="inventoryCount">0</span></a></li>
      <li><a class="sidebar-link" data-section="warehouse" onclick="switchTab('warehouse')">🏢 المستودع <span class="badge" id="warehouseCount">0</span></a></li>
      <li><a class="sidebar-link" data-section="attendance" onclick="switchTab('attendance')">⏰ حضور وانصراف</a></li>
      <li><a class="sidebar-link" data-section="salaries" onclick="switchTab('salaries')">💰 الرواتب</a></li>
      <li><a class="sidebar-link" data-section="warehouse-reports" onclick="switchTab('warehouse-reports')">📋 تقارير المستودع</a></li>
    </ul>
    <div style="margin-top:auto;padding:16px;border-top:1px solid rgba(255,255,255,.08);display:flex;flex-direction:column;gap:6px">
      <button class="logout-btn" onclick="toggleTheme()" id="themeToggleBtn" title="الوضع الليلي/النهاري">🌙</button>
      <button class="logout-btn" onclick="logout()">🚪 خروج</button>
      <button class="logout-btn" onclick="showChangePassword()">🔑 تغيير كلمة السر</button>
    </div>
  </aside>

  <main class="main-content">
    <div class="main-header">
      <div>
        <span class="user-greeting">👋 أهلاً</span>
        <span class="user-name">محمد ابراهيم</span>
      </div>
      <div style="display:flex;gap:8px;align-items:center">
        <span style="font-size:.75rem;color:#94a3b8">💰 الرصيد: <strong style="color:#059669" id="headerBalance">0 ر.س</strong></span>
        <button class="btn btn-sm btn-outline" onclick="exportData()" style="font-size:.75rem">📥 تصدير</button>
        <label class="btn btn-sm btn-outline" style="font-size:.75rem;cursor:pointer">📤 استيراد <input type="file" accept=".json" onchange="importData(event)" style="display:none"></label>
