// ========== MONTHLY GRID ==========
function renderMonthlyGrid() {
  const table = document.getElementById('monthlyGrid');
  const empty = document.getElementById('attendanceEmpty');
  const container = document.getElementById('monthlyGridContainer');
  if (!table) return;

  const monthKey = document.getElementById('attMonth').value;
  const emps = data.attendance;

  if (emps.length === 0) {
    table.innerHTML = '';
    container.style.display = 'none';
    empty.style.display = 'block';
    return;
  }
  container.style.display = 'block';
  empty.style.display = 'none';

  if (!data.attMonthly[monthKey]) {
    data.attMonthly[monthKey] = {};
    for (let d = 1; d <= 31; d++) {
      const ds = String(d);
      data.attMonthly[monthKey][ds] = {};
      emps.forEach(emp => {
        data.attMonthly[monthKey][ds][emp.id] = { in: '8', out: '4' };
      });
    }
  }

  const daysInMonth = new Date(parseInt(monthKey.split('-')[0]), parseInt(monthKey.split('-')[1]), 0).getDate();
  const monthData = data.attMonthly[monthKey] || {};

  for (let d = 1; d <= daysInMonth; d++) {
    const ds = String(d);
    if (!monthData[ds]) monthData[ds] = {};
    emps.forEach(emp => {
      if (monthData[ds][emp.id] === undefined) {
        const shift = getEmpShift(emp.id);
        monthData[ds][emp.id] = { in: shift.in, out: shift.out };
      }
    });
  }

  let html = '<thead>';

  // HEADER ROW 1: employee names
  html += '<tr>';
  html += '<td class="day-col">الموظف</td>';
  emps.forEach(e => {
    html += `<td colspan="2" class="emp-name">${e.name}</td>`;
  });
  html += '<td class="day-col">الموظف</td>';
  html += '</tr>';

  // HEADER ROW 2: sub-headers (حضور | انصراف)
  html += '<tr class="sub-title">';
  html += '<td class="day-col">اليوم</td>';
  emps.forEach(() => { html += '<td>حضور</td><td>انصراف</td>'; });
  html += '<td class="day-col">اليوم</td>';
  html += '</tr></thead><tbody>';

  // DATA ROWS (days 1 to daysInMonth)
  for (let d = 1; d <= daysInMonth; d++) {
    const ds = String(d);
    const dayData = monthData[ds] || {};
    html += '<tr>';
    html += `<td class="day-col">يوم ${d}</td>`;
    emps.forEach(emp => {
      const rec = dayData[emp.id];
      if (rec === null || rec === undefined) {
        const shift = getEmpShift(emp.id);
        html += `<td class="bg-red" onclick="editOffCell('${monthKey}','${ds}',${emp.id})">${shift.in}</td><td class="bg-red" onclick="editOffCell('${monthKey}','${ds}',${emp.id})">${shift.out}</td>`;
      } else {
        const vIn = (rec && rec.in !== undefined) ? rec.in : '8';
        const vOut = (rec && rec.out !== undefined) ? rec.out : '4';
        html += `<td onclick="editCell(this,'${monthKey}','${ds}',${emp.id},'in')">${vIn}</td><td onclick="editCell(this,'${monthKey}','${ds}',${emp.id},'out')">${vOut}</td>`;
      }
    });
    html += `<td class="day-col">يوم ${d}</td>`;
    html += '</tr>';
  }
  html += '</tbody>';
  table.innerHTML = html;
}

