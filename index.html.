      [data-theme="dark"] .payroll-styled-table th { background:#1e293b; color:#e2e8f0; }
      [data-theme="dark"] .payroll-styled-table th, [data-theme="dark"] .payroll-styled-table td { border-color:#475569; color:#e2e8f0; }
