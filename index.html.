function autoWarehouseReport(code, name, qty, branch) {
  const today = new Date().toISOString().split('T')[0];
  const now = new Date();
  const timeStr = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');

  const existing = data.warehouseReports.find(r => r.branch === branch && r.date === today);
  if (existing) {
    existing.items.push({ code, name, qty });
  } else {
    data.warehouseReports.push({
      id: Date.now() + Math.random(),
      branch: branch,
      date: today,
      time: timeStr,
      items: [{ code, name, qty }],
      createdAt: new Date().toISOString()
    });
  }
}

