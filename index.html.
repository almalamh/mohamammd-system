function addWarehouseItem(e) {
  e.preventDefault();
  const code = document.getElementById('whCode').value.trim();
  const name = document.getElementById('whName').value.trim();
  const qty = parseInt(document.getElementById('whQty').value);
  const branch = document.getElementById('whBranch').value;

  if (!code || !name || isNaN(qty) || !branch) { toast('يرجى تعبئة جميع الحقول المطلوبة', 'error'); return; }

  // Deduct from inventory
  const invItem = data.inventory.find(x => x.code === code);
  if (!invItem) {
    toast('⚠️ كود الصنف غير موجود في المخزون', 'error');
    return;
  }
  if (invItem.quantity < qty) {
    if (!confirm(`⚠️ الكمية المطلوبة (${qty}) أكبر من المتوفر (${invItem.quantity}). هل تريد المتابعة؟`)) return;
  }
  invItem.quantity -= qty;

  data.warehouse.push({
    id: Date.now() + Math.random(),
    code: code,
    name: name,
    quantity: qty,
    branch: branch,
    date: new Date().toISOString().split('T')[0],
    createdAt: new Date().toISOString()
  });

  autoWarehouseReport(code, name, qty, branch);
  saveData();
  document.getElementById('warehouseForm').reset();
  document.getElementById('whBranch').value = '';
  toast('✅ تم صرف ' + qty + ' ' + name + ' لفرع ' + branch);
