function saveCellEdit(monthKey, day, empId, field) {
  const val = document.getElementById('cellEditValue').value.trim();
  const isOff = document.getElementById('cellEditOff').checked;

  if (!data.attMonthly[monthKey]) data.attMonthly[monthKey] = {};
  if (!data.attMonthly[monthKey][day]) data.attMonthly[monthKey][day] = {};

  if (isOff) {
    data.attMonthly[monthKey][day][empId] = null;
  } else {
    if (!data.attMonthly[monthKey][day][empId]) {
      const shift = getEmpShift(empId);
      data.attMonthly[monthKey][day][empId] = { in: shift.in, out: shift.out };
    }
    if (field === 'in') data.attMonthly[monthKey][day][empId].in = val;
    else data.attMonthly[monthKey][day][empId].out = val;
  }
  saveData();
  closeModal();
  toast('✅ تم الحفظ');
  renderMonthlyGrid();
}

// ========== DAILY VIEW (CHECK-IN/CHECK-OUT) ==========
function renderDailyView() {
  const grid = document.getElementById('dailyGrid');
  if (!grid) return;
  const dateEl = document.getElementById('attDate');
  if (dateEl && !dateEl.value) dateEl.value = new Date().toISOString().split('T')[0];
  const selectedDate = dateEl ? dateEl.value : new Date().toISOString().split('T')[0];
  if (data.attendance.length === 0) { grid.innerHTML = '<div class="empty-state" style="display:block"><div class="empty-icon">📭</div><p>لا يوجد موظفين</p></div>'; return; }
  grid.innerHTML = data.attendance.map(a => {
    const rec = (a.records || []).find(r => r.date === selectedDate);
    let status, btn;
    if (!rec) {
      status = '<span style="color:#999;font-size:11px">⚪ لم يسجل</span>';
      btn = `<button class="btn btn-sm btn-success" onclick="dailyCheckIn(${a.id})" style="font-size:10px">✅ حضور</button>`;
    } else if (!rec.checkOut) {
      status = `<span style="color:#2e7d32;font-size:11px">✅ ${rec.checkIn}</span>`;
      btn = `<button class="btn btn-sm btn-danger" onclick="dailyCheckOut(${a.id})" style="font-size:10px">🔴 انصراف</button>`;
    } else {
      status = `<span style="color:#2e7d32;font-size:11px">✅ ${rec.checkIn}</span> <span style="color:#c62828;font-size:11px">🔴 ${rec.checkOut}</span>`;
      btn = '<span class="tag tag-green" style="font-size:10px">✔ مكتمل</span>';
    }
    return `<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:#fff;border:1px solid #eee;border-radius:8px">
      <div style="width:28px;height:28px;border-radius:50%;background:#1e3a5f;color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:bold;flex-shrink:0">${a.name.charAt(0)}</div>
      <span style="flex:1;font-weight:600;font-size:13px;color:#1e3a5f">${a.name}</span>
      <span style="display:flex;align-items:center;gap:6px">${status}</span>
      <span style="display:flex;gap:4px">${btn}
        <button class="btn btn-sm btn-danger" onclick="deleteAttEmployee(${a.id})" style="font-size:10px">🗑️</button>
      </span>
    </div>`;
  }).join('');
}

function dailyCheckIn(id) {
  const a = data.attendance.find(x => x.id === id);
  if (!a) return;
  const dateEl = document.getElementById('attDate');
  const selectedDate = dateEl && dateEl.value ? dateEl.value : new Date().toISOString().split('T')[0];
  const now = new Date().toLocaleTimeString('ar-SA', {hour:'2-digit',minute:'2-digit'});
  const existing = (a.records || []).find(r => r.date === selectedDate);
  if (existing) { toast('تم تسجيل الحضور مسبقاً لهذا التاريخ', 'error'); return; }
  a.records.push({date: selectedDate, checkIn: now, checkOut: null});
  saveData();
  renderDailyView();
  toast('✅ تم تسجيل الحضور');
}

function dailyCheckOut(id) {
  const a = data.attendance.find(x => x.id === id);
  if (!a) return;
  const dateEl = document.getElementById('attDate');
  const selectedDate = dateEl && dateEl.value ? dateEl.value : new Date().toISOString().split('T')[0];
  const now = new Date().toLocaleTimeString('ar-SA', {hour:'2-digit',minute:'2-digit'});
  const rec = (a.records || []).find(r => r.date === selectedDate);
  if (!rec) { toast('لم يتم تسجيل الحضور بعد', 'error'); return; }
  if (rec.checkOut) { toast('تم تسجيل الانصراف مسبقاً', 'error'); return; }
  rec.checkOut = now;
  saveData();
  renderDailyView();
  toast('✅ تم تسجيل الانصراف');
}

