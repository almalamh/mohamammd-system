function buildExcelBlob(title, subtitle, headers, colWidths, dataRows, footerTexts, signature, fileName, alignments) {
  const today = new Date().toISOString().split('T')[0];
  let rowsHtml = '';
  (dataRows || []).forEach((row, i) => {
    const bg = i % 2 === 1 ? 'background:#f4f7ff;' : '';
    rowsHtml += `<tr style="${bg}">`;
    row.forEach((cell, ci) => {
      const v = cell != null ? String(cell).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : '';
      const align = (alignments && alignments[ci]) || 'center';
      rowsHtml += `<td style="padding:6px 8px;border:1px solid #b0c4de;font-size:12pt;text-align:${align}">${v}</td>`;
    });
    rowsHtml += `</tr>`;
  });
  const footHtml = (footerTexts || []).map(t =>
    `<tr><td colspan="${headers.length}" style="padding:7px 10px;border:1px solid #b0c4de;font-weight:bold;font-size:13pt;text-align:center;background:#e8effa;color:#1e3a5f">${t}</td></tr>`
  ).join('');
  const sigHtml = signature ? `<div style="text-align:left;margin-top:12px;padding-top:6px;border-top:1px solid #b0c4de;font-size:12pt;color:#1e3a5f"><strong>${signature}</strong></div>` : '';
  const colTags = (colWidths || []).map(w => `<col style="width:${w}px">`).join('');
  const h = `<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
<head><meta charset="UTF-8"><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>البيانات</x:Name><x:WorksheetOptions><x:RightToLeft/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]-->
<style>body{font-family:'Traditional Arabic','Segoe UI',Arial,sans-serif;direction:rtl;padding:20px}.print-date{text-align:left;font-size:10pt;color:#888;margin-bottom:8px}.main-title{font-size:26pt;font-weight:700;color:#1e3a5f;text-align:center;border-bottom:3px double #1e3a5f;padding-bottom:12px;margin-bottom:16px}.sub-title{font-size:12pt;color:#666;text-align:center;margin-bottom:12px}table{border-collapse:collapse;font-size:12pt;margin:0 0 0 auto}th{background:#1e3a5f;color:#fff;padding:7px 8px;border:1px solid #1e3a5f;text-align:center;font-weight:700;font-size:13pt}td{padding:6px 8px;border:1px solid #b0c4de;font-size:12pt;text-align:center}</style></head><body>
<div class="print-date">تاريخ الطباعة: ${today}</div>
<div class="main-title">${title}</div>${subtitle ? `<div class="sub-title">${subtitle}</div>` : ''}
<table style="margin:0 0 0 auto">${colTags}<thead><tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr></thead>
<tbody>${rowsHtml}${footHtml}</tbody></table>${sigHtml}</body></html>`;
  const blob = new Blob(['\uFEFF' + h], { type: 'application/vnd.ms-excel;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = (fileName || title) + '_' + today + '.xls';
  a.click();
  URL.revokeObjectURL(url);
  toast('✅ تم تصدير إكسيل بنجاح');
}

