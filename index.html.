// ========== HIJRI DATE HELPERS ==========
function gregToHijri(gy, gm, gd) {
  // Tabular Islamic calendar (Kuwaiti algorithm)
  let y2 = gy, m2 = gm;
  if (m2 > 2) { m2 -= 3; } else { m2 += 9; y2--; }
  const c = Math.floor(y2 / 100);
  y2 -= 100 * c;
  let jd = Math.floor((146097 * c) / 4) + Math.floor((1461 * y2) / 4) + Math.floor((153 * m2 + 2) / 5) + gd + 1721119;
  jd = jd - 1948440 + 10632;
  const n = Math.floor((jd - 1) / 10631);
  jd = jd - 10631 * n + 354;
  const j = Math.floor((10985 - jd) / 5316) * Math.floor((50 * jd) / 17719) + Math.floor(jd / 5670) * Math.floor((43 * jd) / 15238);
  jd = jd - Math.floor((30 - j) / 15) * Math.floor((17719 * j) / 50) - Math.floor(j / 16) * Math.floor((15238 * j) / 43) + 29;
  const hm = Math.floor((24 * jd) / 709);
  const hd = jd - Math.floor((709 * hm) / 24);
  const hy = 30 * n + j - 30;
  return `${String(hy).padStart(4,'0')}-${String(hm).padStart(2,'0')}-${String(hd).padStart(2,'0')}`;
}

function getHijriToday() {
  try {
    const formatter = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { year: 'numeric', month: '2-digit', day: '2-digit' });
    const parts = formatter.formatToParts(new Date());
    let y, m, d;
    parts.forEach(p => {
      if (p.type === 'year') y = p.value;
      else if (p.type === 'month') m = p.value;
      else if (p.type === 'day') d = p.value;
    });
    if (y && m && d) return `${y}-${m}-${d}`;
  } catch(e) {}
  try {
    const formatter = new Intl.DateTimeFormat('en-u-ca-islamic', { year: 'numeric', month: '2-digit', day: '2-digit' });
    const parts = formatter.formatToParts(new Date());
    let y, m, d;
    parts.forEach(p => {
      if (p.type === 'year') y = p.value;
      else if (p.type === 'month') m = p.value;
      else if (p.type === 'day') d = p.value;
    });
    if (y && m && d) return `${y}-${m}-${d}`;
  } catch(e) {}
  const g = new Date();
  return gregToHijri(g.getFullYear(), g.getMonth() + 1, g.getDate());
}

function getHijriYear() {
  try {
    const formatter = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { year: 'numeric' });
    const y = parseInt(formatter.format(new Date()));
    if (!isNaN(y)) return y;
  } catch(e) {}
  try {
    const formatter = new Intl.DateTimeFormat('en-u-ca-islamic', { year: 'numeric' });
    const y = parseInt(formatter.format(new Date()));
    if (!isNaN(y)) return y;
  } catch(e) {}
  return parseInt(getHijriToday().split('-')[0]);
}

