      if (!sel) return;
      sel.querySelectorAll('option:not(:first-child)').forEach(o => o.remove());
      for (let d = 1; d <= 30; d++) {
        const opt = document.createElement('option');
        opt.value = d.toString().padStart(2, '0'); opt.textContent = d;
        sel.appendChild(opt);
      }
    });
    const today = getHijriToday().split('-');
    ['wIssueYear', 'wIssueMonth', 'wIssueDay'].forEach((id, i) => {
      const el = document.getElementById(id);
      if (el && !el.value) el.value = today[i];
    });
  } catch(e) { console.error('Hijri error:', e); }
}

function getHijriDate(yearEl, monthEl, dayEl) {
  try {
    const y = document.getElementById(yearEl).value;
    const m = document.getElementById(monthEl).value;
    const d = document.getElementById(dayEl).value;
    if (!y || !m || !d) return null;
    return `${y}-${m}-${d}`;
  } catch(e) { return null; }
}

function hijriDiffDays(hijriDateStr) {
  try {
    if (!hijriDateStr) return 999;
    const todayParts = getHijriToday().split('-');
    const dateParts = hijriDateStr.split('-');
    const todayNum = parseInt(todayParts[0]) * 384 + parseInt(todayParts[1]) * 32 + parseInt(todayParts[2]);
    const dateNum = parseInt(dateParts[0]) * 384 + parseInt(dateParts[1]) * 32 + parseInt(dateParts[2]);
    return dateNum - todayNum;
  } catch(e) { return 999; }
}

